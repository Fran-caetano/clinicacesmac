# copie este arquivo para .env e preencha com os dados reais
# nunca commitar o .env de verdade

# string de conexao do Postgres (Neon, Railway, Supabase-so-banco ou local)
DATABASE_URL=postgres://usuario:senha@localhost:5432/psicesmac

# porta em que o servidor Express vai escutar
PORT=3000

# chave usada para assinar o cookie de sessao - gerar uma string aleatoria longa
SESSION_SECRET=troque_esta_chave_por_algo_aleatorio_e_grande

# se true, o cookie de sessao so e enviado em HTTPS (usar true em producao)
COOKIE_SECURE=false
